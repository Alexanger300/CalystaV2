# Configuration Neon PostgreSQL - Exemple
# Remplacez les valeurs par vos identifiants Neon depuis https://console.neon.tech

# Format de la connection string Neon :
# postgresql://user:password@host/database?sslmode=require

# Exemple complet :
# DATABASE_URL=postgresql://neondb_owner:MySecurePassword123@ep-lucky-butterfly-a1b2c3.us-east-2.aws.neon.tech/neondb?sslmode=require

DATABASE_URL=postgresql://neondb_owner:YOUR_ACTUAL_PASSWORD@YOUR_HOST.neon.tech/neondb?sslmode=require